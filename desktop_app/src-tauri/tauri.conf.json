{
  "$schema": "https://tauri.app/v1/schemas/tauri.schema.json",
  "package": {
    "productName": "Robo-Binance",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend_next run dev",
    "beforeBuildCommand": "npm --prefix ../frontend_next run build",
    "distDir": "../frontend_next/out",
    "devPath": "http://localhost:3000"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.robo.binance",
      "targets": ["msi", "nsis"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "allowlist": {
      "all": true
    },
    "windows": [
      {
        "title": "Robo Binance",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
