PORT=3001

# ─── Binance API Keys ─────────────────────────────────────────────────────────
BINANCE_API_KEY="COLOQUE_SUA_API_KEY_AQUI"
BINANCE_API_SECRET="COLOQUE_SEU_API_SECRET_AQUI"

# ─── Modo de operação: TESTNET (demo) ────────────────────────────────────────
# BINANCE_TESTNET=true  → usa a conta demo/testnet da Binance (sem dinheiro real)
# BINANCE_TESTNET=false → usa a conta REAL da Binance
BINANCE_TESTNET=true

# ─── Habilitar execução LIVE (conta real) ────────────────────────────────────
# Mantenha ALLOW_LIVE_TRADING=false até:
#   1. Ter um backtest com Win Rate > 55%, PF > 1.3 e Drawdown < 15%
#   2. Ter pelo menos 30 trades rentáveis na conta demo
# Só mude para true depois de preencher esses critérios.
ALLOW_LIVE_TRADING=false

# ─── Modo do bot ─────────────────────────────────────────────────────────────
# BOT_MODE=FUTURES → opera futuros perpétuos (com alavancagem)
# BOT_MODE=SPOT    → opera spot (sem alavancagem, apenas BUY/SELL)
BOT_MODE=FUTURES
